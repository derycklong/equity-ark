# OpenAI-compatible LLM endpoint for financial advice
# Leave blank to disable LLM-powered advice (rule-based advice still works)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
